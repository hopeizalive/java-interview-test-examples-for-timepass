<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="studyPU" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>com.example.jpa.interview.entity.Account</class>
        <class>com.example.jpa.interview.entity.Article</class>
        <class>com.example.jpa.interview.entity.Author</class>
        <class>com.example.jpa.interview.entity.Book</class>
        <class>com.example.jpa.interview.entity.CardPayment</class>
        <class>com.example.jpa.interview.entity.Category</class>
        <class>com.example.jpa.interview.entity.CheckingAccount</class>
        <class>com.example.jpa.interview.entity.Country</class>
        <class>com.example.jpa.interview.entity.Customer</class>
        <class>com.example.jpa.interview.entity.Document</class>
        <class>com.example.jpa.interview.entity.Invoice</class>
        <class>com.example.jpa.interview.entity.Job</class>
        <class>com.example.jpa.interview.entity.OrderLine</class>
        <class>com.example.jpa.interview.entity.Payment</class>
        <class>com.example.jpa.interview.entity.WirePayment</class>
        <class>com.example.jpa.interview.entity.Product</class>
        <class>com.example.jpa.interview.entity.Reservation</class>
        <class>com.example.jpa.interview.entity.RetailOrder</class>
        <class>com.example.jpa.interview.entity.SeqAuthor</class>
        <class>com.example.jpa.interview.entity.Ticket</class>
        <class>com.example.jpa.interview.entity.User</class>
        <class>com.example.jpa.interview.entity.UserProfile</class>
        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="org.h2.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:h2:mem:study;DB_CLOSE_DELAY=-1"/>
            <property name="jakarta.persistence.jdbc.user" value="sa"/>
            <property name="jakarta.persistence.jdbc.password" value=""/>
            <property name="hibernate.hbm2ddl.auto" value="create"/>
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>
    </persistence-unit>

    <persistence-unit name="ordersPU" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>com.example.jpa.interview.entity.StudyOrder</class>
        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="org.h2.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:h2:mem:orders;DB_CLOSE_DELAY=-1"/>
            <property name="jakarta.persistence.jdbc.user" value="sa"/>
            <property name="jakarta.persistence.jdbc.password" value=""/>
            <property name="hibernate.hbm2ddl.auto" value="create"/>
        </properties>
    </persistence-unit>

    <persistence-unit name="billingPU" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>com.example.jpa.interview.entity.StudyInvoice</class>
        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="org.h2.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:h2:mem:billing;DB_CLOSE_DELAY=-1"/>
            <property name="jakarta.persistence.jdbc.user" value="sa"/>
            <property name="jakarta.persistence.jdbc.password" value=""/>
            <property name="hibernate.hbm2ddl.auto" value="create"/>
        </properties>
    </persistence-unit>
</persistence>
